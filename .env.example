NEXT_PUBLIC_ENV_IS_LOCAL=true
FDA_API_KEY=your_openfda_api_key_here

# Groq API — used to parse supplier emails and analyse action email modals
# Get a free key at: console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Gmail API — OAuth 2.0 credentials (also used by NextAuth Google provider)
# See: console.cloud.google.com → APIs & Services → Credentials
GMAIL_CLIENT_ID=your_oauth_client_id_here
GMAIL_CLIENT_SECRET=your_oauth_client_secret_here
# Fallback single-user token (used when no user session exists)
# Obtained via OAuth Playground (developers.google.com/oauthplayground)
# Required scopes (select both):
#   https://www.googleapis.com/auth/gmail.readonly
#   https://www.googleapis.com/auth/gmail.send
GMAIL_REFRESH_TOKEN=your_refresh_token_here
# Fallback Gmail address (used with the refresh token above)
GMAIL_USER_EMAIL=your_email@gmail.com

# NextAuth
NEXTAUTH_URL=http://localhost:3000
# Generate with: openssl rand -base64 32
NEXTAUTH_SECRET=your_nextauth_secret_here
